# ─────────────────────────────────────────────────────────────────
# AgriTrace Environment Variables
# Copy this file to .env.local and fill in real values
# NEVER commit .env.local to git
# ─────────────────────────────────────────────────────────────────

# ── App ────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── Supabase ───────────────────────────────────────────────────────
# Get these from your Supabase project → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here   # NEVER expose publicly

# ── WhatsApp Business Cloud API ────────────────────────────────────
# Get from Meta Developer Console → WhatsApp → API Setup
WHATSAPP_PHONE_NUMBER_ID=your-phone-number-id
WHATSAPP_ACCESS_TOKEN=your-permanent-access-token
WHATSAPP_VERIFY_TOKEN=your-custom-webhook-verify-token  # any string you choose
WHATSAPP_APP_SECRET=your-meta-app-secret               # used to verify webhook signatures

# ── Google Gemini AI ───────────────────────────────────────────────
# Get from https://aistudio.google.com/app/apikey
# IMPORTANT: Use gemini-2.5-flash-lite — gemini-2.0-flash is deprecated June 2026
GEMINI_API_KEY=your-gemini-api-key-here

# ── Paystack ───────────────────────────────────────────────────────
# Get from https://dashboard.paystack.com/#/settings/developers
NEXT_PUBLIC_PAYSTACK_PUBLIC_KEY=pk_test_your-public-key
PAYSTACK_SECRET_KEY=sk_test_your-secret-key

# ── Cron Security ──────────────────────────────────────────────────
# Random secret for securing /api/cron/* endpoints
CRON_SECRET=generate-a-random-secret-here
